    <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bias Analysis Report — Rifair AI</title>
<style>
  /* ── RESET & BASE ── */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 
                 'Segoe UI', sans-serif;
    background: #ffffff;
    color: #1a1a1a;
    font-size: 14px;
    line-height: 1.6;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* ── PAGE SETTINGS ── */
  @page {
    size: A4;
    margin: 0;
  }

  @media print {
    body { margin: 0; }
    .page { page-break-after: always; }
    .page:last-child { page-break-after: avoid; }
    .no-break { page-break-inside: avoid; }
    .force-break { page-break-before: always; }
  }

  /* ── DESIGN TOKENS ── */
  :root {
    --green:        #0a3d2e;
    --green-mid:    #1D9E75;
    --green-light:  #f0fdf4;
    --green-border: #d1fae5;
    --red:          #dc2626;
    --red-light:    #fef2f2;
    --red-border:   #fecaca;
    --amber:        #d97706;
    --amber-light:  #fffbeb;
    --amber-border: #fde68a;
    --gray-50:      #f9fafb;
    --gray-100:     #f3f4f6;
    --gray-200:     #e5e7eb;
    --gray-400:     #9ca3af;
    --gray-500:     #6b7280;
    --gray-700:     #374151;
    --gray-900:     #111827;
  }

  /* ── PAGE WRAPPER ── */
  .page {
    width: 210mm;
    min-height: 297mm;
    padding: 0;
    position: relative;
    background: #fff;
    overflow: hidden;
  }

  /* ══════════════════════════════
     PAGE 1 — COVER
  ══════════════════════════════ */
  .cover {
    background: var(--green);
    width: 100%;
    height: 297mm;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .cover-bg-circle {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    top: -100px;
    right: -100px;
  }
  .cover-bg-circle-2 {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    bottom: 100px;
    left: -80px;
  }

  .cover-header {
    padding: 40px 48px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .cover-logo {
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.5px;
    font-family: 'Courier New', monospace;
  }
  .cover-logo span { color: var(--green-mid); }
  .cover-badge {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.8);
    font-size: 10px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 20px;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 48px;
    position: relative;
    z-index: 1;
  }

  .cover-report-type {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 20px;
  }
  .cover-title {
    font-size: 42px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 16px;
    max-width: 480px;
  }
  .cover-subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 48px;
    max-width: 400px;
    line-height: 1.6;
  }

  /* Score ring on cover */
  .cover-score-block {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 48px;
  }
  .score-ring-wrap {
    position: relative;
    width: 100px;
    height: 100px;
  }
  .score-ring-wrap svg {
    transform: rotate(-90deg);
  }
  .score-ring-number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
  }
  .cover-score-meta {
    color: rgba(255,255,255,0.8);
  }
  .cover-score-meta .label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .1em;
    opacity: .6;
    margin-bottom: 4px;
  }
  .cover-score-meta .verdict {
    font-size: 22px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 4px;
  }
  .cover-score-meta .sub {
    font-size: 13px;
    opacity: .6;
  }

  /* Cover meta grid */
  .cover-meta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 24px;
  }
  .cover-meta-item {
    padding-right: 24px;
  }
  .cover-meta-item + .cover-meta-item {
    padding-left: 24px;
    border-left: 1px solid rgba(255,255,255,0.12);
  }
  .cover-meta-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 4px;
  }
  .cover-meta-value {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
  }

  .cover-footer {
    padding: 24px 48px;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .cover-footer p {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
  }
  .cover-footer .confidential {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 3px 10px;
    border-radius: 4px;
  }

  /* ══════════════════════════════
     INTERIOR PAGES
  ══════════════════════════════ */
  .interior {
    padding: 40px 48px;
    min-height: 297mm;
    display: flex;
    flex-direction: column;
  }

  /* Page header */
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--green);
    margin-bottom: 32px;
  }
  .page-header .logo {
    font-family: 'Courier New', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--green);
    letter-spacing: -0.5px;
  }
  .page-header .page-info {
    font-size: 11px;
    color: var(--gray-400);
    text-align: right;
  }
  .page-header .page-info strong {
    display: block;
    color: var(--gray-700);
    font-size: 12px;
  }

  /* Page footer */
  .page-footer {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    color: var(--gray-400);
  }

  /* Section title */
  .section-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--gray-400);
    margin-bottom: 16px;
  }

  /* ── EXECUTIVE SUMMARY ── */
  .exec-summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
  }
  .summary-card {
    border-radius: 12px;
    padding: 20px;
    border: 1px solid var(--gray-200);
  }
  .summary-card.green {
    background: var(--green-light);
    border-color: var(--green-border);
  }
  .summary-card.red {
    background: var(--red-light);
    border-color: var(--red-border);
  }
  .summary-card.amber {
    background: var(--amber-light);
    border-color: var(--amber-border);
  }
  .summary-card .card-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: 8px;
  }
  .summary-card.green .card-label { color: #065f46; }
  .summary-card.red .card-label { color: #7f1d1d; }
  .summary-card.amber .card-label { color: #713f12; }
  .summary-card .card-value {
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .summary-card.green .card-value { color: var(--green); }
  .summary-card.red .card-value { color: var(--red); }
  .summary-card.amber .card-value { color: var(--amber); }
  .summary-card .card-sub {
    font-size: 12px;
    color: var(--gray-500);
  }

  /* Insight box */
  .insight-box {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-left: 4px solid var(--green);
    border-radius: 0 10px 10px 0;
    padding: 16px 20px;
    margin-bottom: 20px;
  }
  .insight-box p {
    font-size: 13px;
    color: var(--gray-700);
    line-height: 1.7;
  }

  /* Bias category bar chart */
  .bias-bar-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }
  .bias-bar-label {
    font-size: 12px;
    color: var(--gray-700);
    width: 140px;
    flex-shrink: 0;
  }
  .bias-bar-track {
    flex: 1;
    height: 8px;
    background: var(--gray-100);
    border-radius: 4px;
    overflow: hidden;
  }
  .bias-bar-fill {
    height: 100%;
    border-radius: 4px;
  }
  .fill-critical { background: #dc2626; }
  .fill-high     { background: #ea580c; }
  .fill-moderate { background: #d97706; }
  .fill-low      { background: #65a30d; }
  .bias-bar-count {
    font-size: 12px;
    font-weight: 600;
    color: var(--gray-700);
    width: 20px;
    text-align: right;
    flex-shrink: 0;
  }

  /* ── QUESTION CARDS ── */
  .question-card {
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    page-break-inside: avoid;
  }

  .question-header {
    padding: 14px 18px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    border-bottom: 1px solid var(--gray-100);
  }
  .question-header.severely-biased {
    background: #fff5f5;
  }
  .question-header.biased {
    background: #fffbeb;
  }
  .question-header.mild {
    background: #f0f9ff;
  }
  .question-header.neutral {
    background: var(--gray-50);
  }

  .q-number {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    color: white;
  }
  .q-number.severely-biased { background: #dc2626; }
  .q-number.biased           { background: #d97706; }
  .q-number.mild             { background: #2563eb; }
  .q-number.neutral          { background: var(--gray-400); }

  .q-text {
    flex: 1;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-900);
    line-height: 1.5;
  }

  .q-score-badge {
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    flex-shrink: 0;
  }
  .q-score-badge.severely-biased {
    background: #fee2e2;
    color: #991b1b;
  }
  .q-score-badge.biased {
    background: #fef3c7;
    color: #92400e;
  }
  .q-score-badge.mild {
    background: #dbeafe;
    color: #1e40af;
  }
  .q-score-badge.neutral {
    background: var(--gray-100);
    color: var(--gray-600);
  }

  .question-body {
    padding: 16px 18px;
  }

  .q-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .q-tag {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 20px;
    background: var(--gray-100);
    color: var(--gray-600);
    text-transform: capitalize;
  }

  .q-explanation {
    font-size: 12px;
    color: var(--gray-700);
    line-height: 1.6;
    margin-bottom: 14px;
    padding: 10px 14px;
    background: var(--gray-50);
    border-radius: 8px;
    border-left: 3px solid var(--gray-300);
  }

  .q-rewrite-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--green);
    margin-bottom: 6px;
  }
  .q-rewrite {
    font-size: 12px;
    color: var(--green);
    line-height: 1.6;
    padding: 10px 14px;
    background: var(--green-light);
    border-radius: 8px;
    border-left: 3px solid var(--green-mid);
  }

  .q-law {
    font-size: 11px;
    color: #7c3aed;
    margin-top: 8px;
    padding: 6px 12px;
    background: #f5f3ff;
    border-radius: 6px;
    display: inline-block;
  }

  /* ── RECOMMENDATIONS ── */
  .rec-item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--gray-100);
    page-break-inside: avoid;
  }
  .rec-item:last-child { border-bottom: none; }
  .rec-number {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--green);
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .rec-content h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-900);
    margin-bottom: 4px;
  }
  .rec-content p {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.5;
  }

  /* ── FAIRNESS SCORECARD ── */
  .scorecard-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }
  .scorecard-item {
    text-align: center;
    padding: 16px 8px;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    background: var(--gray-50);
  }
  .scorecard-item .si-value {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .scorecard-item .si-label {
    font-size: 10px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  /* Divider */
  .divider {
    border: none;
    border-top: 1px solid var(--gray-200);
    margin: 24px 0;
  }

  /* Two column layout */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  /* ── VERDICT STRIP ── */
  .verdict-strip {
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .verdict-strip.severely-biased {
    background: #fef2f2;
    border: 1px solid #fecaca;
  }
  .verdict-strip.biased {
    background: #fffbeb;
    border: 1px solid #fde68a;
  }
  .verdict-strip.mild {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
  }
  .verdict-strip.clean {
    background: var(--green-light);
    border: 1px solid var(--green-border);
  }
  .verdict-text h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .verdict-strip.severely-biased .verdict-text h3 { color: #991b1b; }
  .verdict-strip.biased .verdict-text h3 { color: #92400e; }
  .verdict-strip.mild .verdict-text h3 { color: #1e40af; }
  .verdict-strip.clean .verdict-text h3 { color: var(--green); }
  .verdict-text p {
    font-size: 12px;
    color: var(--gray-500);
  }
  .verdict-score {
    text-align: right;
  }
  .verdict-score .big-score {
    font-size: 48px;
    font-weight: 800;
    line-height: 1;
  }
  .verdict-strip.severely-biased .verdict-score .big-score { color: #dc2626; }
  .verdict-strip.biased .verdict-score .big-score { color: #d97706; }
  .verdict-strip.mild .verdict-score .big-score { color: #2563eb; }
  .verdict-strip.clean .verdict-score .big-score { color: var(--green); }
  .verdict-score .score-label {
    font-size: 11px;
    color: var(--gray-400);
  }

</style>
</head>
<body>

<!-- ══════════════════════════════
     PAGE 1 — COVER
══════════════════════════════ -->
<div class="page">
<div class="cover">
  <div class="cover-bg-circle"></div>
  <div class="cover-bg-circle-2"></div>

  <div class="cover-header">
    <div class="cover-logo">
      <img src="{{logoBase64}}" class="c-logo-img" alt="Rifair AI" style="height: 50px;">
    </div>
    <div class="cover-badge">Confidential Report</div>
  </div>

  <div class="cover-body">
    <div class="cover-report-type">{{reportTypeLabel}}</div>
    <h1 class="cover-title">{{reportTitle}}</h1>
    <p class="cover-subtitle">
      {{reportSubtitle}}
    </p>

    <!-- Score ring -->
    <div class="cover-score-block">
      <div class="score-ring-wrap">
        <svg width="100" height="100" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="40"
            fill="none"
            stroke="rgba(255,255,255,0.15)"
            stroke-width="8"/>
          <circle cx="50" cy="50" r="40"
            fill="none"
            stroke="{{scoreColorHex}}"
            stroke-width="8"
            stroke-dasharray="{{biasScoreArc}} 251.2"
            stroke-linecap="round"/>
        </svg>
        <div class="score-ring-number">{{overallBiasScore}}</div>
      </div>
      <div class="cover-score-meta">
        <div class="label">Overall Bias Score</div>
        <div class="verdict">{{verdictLabel}}</div>
        <div class="sub">{{questionCount}} questions analysed</div>
      </div>
    </div>

    <div class="cover-meta-grid">
      <div class="cover-meta-item">
        <div class="cover-meta-label">Generated on</div>
        <div class="cover-meta-value">{{generatedDate}}</div>
      </div>
      <div class="cover-meta-item">
        <div class="cover-meta-label">Analysed by</div>
        <div class="cover-meta-value">{{userName}}</div>
      </div>
      <div class="cover-meta-item">
        <div class="cover-meta-label">Legal risk</div>
        <div class="cover-meta-value">{{legalRiskLevel}}</div>
      </div>
    </div>
  </div>

  <div class="cover-footer">
    <p>Generated by Rifair AI · rifair.ai</p>
    <div class="confidential">Confidential</div>
  </div>
</div>
</div>

<!-- ══════════════════════════════
     PAGE 2 — EXECUTIVE SUMMARY
══════════════════════════════ -->
<div class="page">
<div class="interior">
  <div class="page-header">
    <div class="logo">
      <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
    </div>
    <div class="page-info">
      <strong>{{reportTypeLabel}}</strong>
      Page 2 of 5
    </div>
  </div>

  <div class="section-title">Executive Summary</div>

  <div class="verdict-strip {{verdictClass}}">
    <div class="verdict-text">
      <h3>{{verdictHeadline}}</h3>
      <p>{{verdictSummary}}</p>
    </div>
    <div class="verdict-score">
      <div class="big-score">{{overallBiasScore}}</div>
      <div class="score-label">/ 100 bias score</div>
    </div>
  </div>

  <div class="exec-summary-grid">
    <div class="summary-card red">
      <div class="card-label">Biased questions</div>
      <div class="card-value">{{biasedCount}}</div>
      <div class="card-sub">{{biasedPercent}}% of total</div>
    </div>
    <div class="summary-card green">
      <div class="card-label">Clean questions</div>
      <div class="card-value">{{cleanCount}}</div>
      <div class="card-sub">Pass without changes</div>
    </div>
    <div class="summary-card amber">
      <div class="card-label">Fairness score</div>
      <div class="card-value">{{fairnessScore}}%</div>
      <div class="card-sub">Below acceptable threshold</div>
    </div>
    <div class="summary-card red">
      <div class="card-label">Legal risk level</div>
      <div class="card-value" style="font-size:20px;padding-top:8px">{{legalRiskLevel}}</div>
      <div class="card-sub">May violate employment law</div>
    </div>
  </div>

  <div class="insight-box">
    <p>{{overallSummary}}</p>
  </div>

  <div class="section-title" style="margin-top:4px">Bias by category</div>
  {{#each biasCategories}}
  <div class="bias-bar-row no-break">
    <div class="bias-bar-label">{{this.label}}</div>
    <div class="bias-bar-track">
      <div class="bias-bar-fill fill-{{this.severityClass}}" style="width:{{this.percent}}%"></div>
    </div>
    <div class="bias-bar-count">{{this.count}}</div>
  </div>
  {{/each}}

  <div class="page-footer">
    <span>Rifair AI — {{reportTypeLabel}} — Confidential</span>
    <span>Page 2 of 5</span>
  </div>
</div>
</div>

<!-- ══════════════════════════════
     PAGE 3 — QUESTION ANALYSIS
══════════════════════════════ -->
<div class="page">
<div class="interior">
  <div class="page-header">
    <div class="logo">
      <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
    </div>
    <div class="page-info">
      <strong>{{reportTypeLabel}}</strong>
      Page 3 of 5
    </div>
  </div>

  <div class="section-title">Question-by-question analysis</div>

  {{#each questions}}
  <div class="question-card no-break">
    <div class="question-header {{this.severityClass}}">
      <div class="q-number {{this.severityClass}}">{{this.index}}</div>
      <div class="q-text">
        {{this.original}}
      </div>
      <div class="q-score-badge {{this.severityClass}}">{{this.score}} / 100</div>
    </div>
    <div class="question-body">
      {{#if this.categories.length}}
      <div class="q-tags">
        {{#each this.categories}}
        <span class="q-tag">{{this}}</span>
        {{/each}}
      </div>
      {{else}}
      <div class="q-tags">
        <span class="q-tag" style="background:#d1fae5;color:#065f46">Clean</span>
      </div>
      {{/if}}
      
      {{#if this.primaryIssue}}
      <div class="q-primary-issue" style="font-weight: 600; font-size: 11px; margin-bottom: 4px; color: var(--gray-900);">
        {{this.primaryIssue}}
      </div>
      {{/if}}

      <div class="q-explanation" {{#if this.isClean}}style="border-left-color:#16a34a"{{/if}}>
        {{this.explanation}}
      </div>
      
      {{#if this.psychologicalImpact}}
      <div class="q-impact" style="font-size: 11px; color: #b45309; margin-bottom: 14px; padding-left: 14px; border-left: 2px solid #fcd34d;">
        <strong>Impact:</strong> {{this.psychologicalImpact}}
      </div>
      {{/if}}

      {{#if this.rewritten}}
      <div class="q-rewrite-label">✓ Bias-free rewrite</div>
      <div class="q-rewrite">
        {{this.rewritten}}
        {{#if this.rewriteRationale}}
        <div style="font-size: 11px; margin-top: 8px; opacity: 0.85; border-top: 1px dashed rgba(29, 158, 117, 0.3); padding-top: 6px;">
          <strong>Why it's better:</strong> {{this.rewriteRationale}}
        </div>
        {{/if}}
      </div>
      {{/if}}
      
      {{#if this.lawViolation}}
      <div class="q-law">⚖ {{this.lawViolation}}</div>
      {{/if}}
    </div>
  </div>
  {{/each}}

  <div class="page-footer">
    <span>Rifair AI — {{reportTypeLabel}} — Confidential</span>
    <span>Page 3 of 5</span>
  </div>
</div>
</div>

<!-- ══════════════════════════════
     PAGE 4 — RECOMMENDATIONS
══════════════════════════════ -->
<div class="page">
<div class="interior">
  <div class="page-header">
    <div class="logo">
      <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
    </div>
    <div class="page-info">
      <strong>{{reportTypeLabel}}</strong>
      Page 4 of 5
    </div>
  </div>

  <div class="section-title">Recommended actions</div>

  {{#each recommendations}}
  <div class="rec-item no-break">
    <div class="rec-number">{{this.index}}</div>
    <div class="rec-content">
      <h4>{{this.title}}</h4>
      <p>{{this.description}}</p>
    </div>
  </div>
  {{/each}}

  <hr class="divider">

  <div class="section-title">Legal risk summary</div>

  <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:12px;padding:20px 24px;margin-bottom:16px" class="no-break">
    <div style="font-size:13px;font-weight:600;color:#7f1d1d;margin-bottom:10px">High-risk violations detected</div>
    <div style="font-size:12px;color:#991b1b;line-height:1.8">
      {{#each legalRisks}}
      ⚖ {{this}}<br>
      {{/each}}
    </div>
  </div>

  <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:12px;padding:16px 20px;font-size:12px;color:var(--gray-500);line-height:1.7">
    <strong style="color:var(--gray-700)">Disclaimer:</strong> This report is generated by an AI tool and is intended to assist human decision-making. It does not constitute legal advice. Please consult qualified employment law counsel for definitive legal guidance.
  </div>

  <div class="page-footer">
    <span>Rifair AI — {{reportTypeLabel}} — Confidential</span>
    <span>Page 4 of 5</span>
  </div>
</div>
</div>

