{{!-- interview_kit.hbs --}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>{{{printMasterCss}}}</style>
</head>
<body class="report-kit density-medium">

  <!-- COVER PAGE -->
  <div class="page cover cover-kit">
    <div class="cover-shape-1"></div>
    <div class="cover-shape-2"></div>
    <div class="cover-shape-3"></div>
    
    <div class="cover-nav">
      <div class="c-logo">
        <img src="{{logoBase64}}" class="c-logo-img" alt="Rifair AI">
      </div>
      <div class="c-badge">Professional Interview Kit</div>
    </div>

    <div class="cover-content">
      <div class="cover-eyebrow">
        <div class="cover-eyebrow-line" style="background: var(--theme-green);"></div>
        <div class="cover-eyebrow-text" style="color: var(--theme-green);">Structured Interviewing Suite</div>
      </div>
      
      <h1 class="cover-heading" style="color: var(--theme-green);">{{role}} <span style="color: var(--gray-700); opacity: 0.4;">Interview Kit</span></h1>
      <p class="cover-subheading">A structured, bias-verified assessment kit designed for {{experience}} candidates in the {{companyType}} industry.</p>

      <div class="hero-score">
        <div class="hs-number">{{questions.length}}</div>
        <div class="hs-meta">
          <div class="hs-label">Questions in Bank</div>
          <div class="hs-verdict">{{biasVerdict}}</div>
          <div class="hs-sub">Estimated Duration: {{duration}}</div>
        </div>
      </div>

      <div class="cover-meta">
        <div class="cm-item">
          <div class="cm-label">Organization</div>
          <div class="cm-value">{{meta.organizationName}}</div>
        </div>
        <div class="cm-item">
          <div class="cm-label">Generated By</div>
          <div class="cm-value">{{meta.userName}}</div>
        </div>
        <div class="cm-item">
          <div class="cm-label">Kit Version</div>
          <div class="cm-value">v1.2 (Active)</div>
        </div>
        <div class="cm-item">
          <div class="cm-label">Audit Date</div>
          <div class="cm-value">{{meta.generatedDate}}</div>
        </div>
      </div>
    </div>

    <div class="cover-footer">
      <div class="cf-left">
        Rifair AI Hiring Intelligence — v2.4.0<br>
        Structured Assessment Methodology
      </div>
      <div class="cf-right">ID: {{meta.reportId}}</div>
    </div>
  </div>

  <!-- ASSESSMENT STRATEGY -->
  <div class="page interior-page">
    <div class="ip-header">
      <div class="ip-logo">
        <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
      </div>
      <div class="ip-meta">
        <strong>ASSESSMENT STRATEGY</strong>
        {{meta.reportId}} · {{meta.generatedDate}}
      </div>
    </div>

    <div class="section-label">Executive Strategy Overview</div>
    <div class="insight">
      {{kitSummary}}
    </div>

    <div class="section-label">Competency Weightage & Scoring Strategy</div>
    <div style="margin-bottom: 32px;">
      {{#each competencyWeights}}
      <div class="comp-row">
        <div class="cr-top">
          <div class="cr-name">{{name}}</div>
          <div class="cr-badge s4">{{weight}}% Weight</div>
        </div>
        <div class="cr-track">
          <div class="cr-fill s4" style="width: {{weight}}%;"></div>
        </div>
        <div class="cr-note">{{weightNote}}</div>
      </div>
      {{/each}}
    </div>

    <div class="section-label">Question Type Distribution</div>
    <div class="stats-grid">
      <div class="stat-card sc-green">
        <div class="sc-label">Behavioral</div>
        <div class="sc-value">{{behavioralCount}}</div>
        <div class="sc-sub">STAR Method</div>
      </div>
      <div class="stat-card sc-green">
        <div class="sc-label">Technical</div>
        <div class="sc-value">{{technicalCount}}</div>
        <div class="sc-sub">Skill Validation</div>
      </div>
      <div class="stat-card sc-amber">
        <div class="sc-label">Situational</div>
        <div class="sc-value">{{situationalCount}}</div>
        <div class="sc-sub">Scenario Based</div>
      </div>
      <div class="stat-card sc-purple">
        <div class="sc-label">Total Time</div>
        <div class="sc-value">{{duration}}</div>
        <div class="sc-sub">Incl. Buffer</div>
      </div>
    </div>

    <div class="ip-footer">
      <div>© 2026 Rifair AI Intelligence. All rights reserved.</div>
      <div>Interview Strategy</div>
    </div>
  </div>

  <!-- QUESTION BANK -->
  {{#chunk questions 4}}
  <div class="page interior-page">
    <div class="ip-header">
      <div class="ip-logo">
        <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
      </div>
      <div class="ip-meta">
        <strong>QUESTION BANK {{#if (gt chunkIndex 1)}} (Part {{chunkIndex}}){{/if}}</strong>
        {{meta.reportId}} · {{meta.generatedDate}}
      </div>
    </div>

    <div class="section-label">Interview Question Bank</div>

    {{#each chunkItems}}
    <div class="q-card" style="border-top: 4px solid {{numberBg}};">
      <div class="qh" style="background: {{headerBg}}; border-bottom: 1px solid {{headerBorder}};">
        <div class="qn" style="background: {{numberBg}};">{{index}}</div>
        <div class="qtext">"{{text}}"</div>
        <div class="q-pill" style="background: {{pillBg}}; color: {{pillColor}};">{{type}}</div>
      </div>
      <div class="qb">
        <div class="q-tags">
          {{#each tags}}
          <div class="q-tag">{{this}}</div>
          {{/each}}
          <div class="q-tag">⏱ {{timing}}</div>
        </div>
        
        <div class="q-rewrite-header" style="color: {{typeColorText}};">
          <div class="q-rewrite-dot" style="background: {{typeColorText}};"></div>
          Evaluation Guide: Strong Answer Look-fors
        </div>
        {{#if strongAnswer}}
        <div class="q-exp" style="background: white; border-left-color: {{numberBg}};">
          {{strongAnswer}}
        </div>
        {{/if}}

        {{#if hasRedFlag}}
        <div class="q-law" style="background: #fff1f2; color: #be123c; border-color: #fecdd3;">⚠ Red Flag: {{redFlag}}</div>
        {{/if}}
      </div>
    </div>
    {{/each}}

    <div class="ip-footer">
      <div>Structured Interview Kit Document</div>
      <div>Question Bank — Page {{chunkIndex}}</div>
    </div>
  </div>
  {{/chunk}}

  <!-- EVALUATION GUIDE -->
  <div class="page interior-page">
    <div class="ip-header">
      <div class="ip-logo">
        <img src="{{logoBase64}}" class="ip-logo-img" alt="Rifair AI">
      </div>
      <div class="ip-meta">
        <strong>INTERVIEWER GUIDELINES</strong>
        {{meta.reportId}} · {{meta.generatedDate}}
      </div>
    </div>

    <div class="section-label">How to use this kit</div>
    <div class="insight">
      Structured interviews are shown to be 2.5x more predictive of job performance than unstructured ones. Follow these guidelines to ensure maximum effectiveness and fairness.
    </div>

    <div class="rec-row">
      <div class="rec-num">1</div>
      <div class="rec-text">
        <h4>Ask every candidate the same questions</h4>
        <p>To ensure a fair comparison, maintain the sequence and phrasing of the core questions for all applicants.</p>
      </div>
    </div>

    <div class="rec-row">
      <div class="rec-num">2</div>
      <div class="rec-text">
        <h4>Score immediately after the interview</h4>
        <p>Recall bias increases significantly after 30 minutes. Use the Evaluation Scorecard provided in Rifair AI to log scores while fresh.</p>
      </div>
    </div>

    <div class="rec-row">
      <div class="rec-num">3</div>
      <div class="rec-text">
        <h4>Probe for specific examples</h4>
        <p>If a candidate is vague, use follow-up probes: "Tell me exactly what YOUR role was in that situation" or "What was the measurable outcome?"</p>
      </div>
    </div>

    <div class="rec-row">
      <div class="rec-num">4</div>
      <div class="rec-text">
        <h4>Beware of "Like-me" bias</h4>
        <p>Focus purely on the competency look-fors identified in this kit, rather than shared hobbies or common backgrounds.</p>
      </div>
    </div>

    <div class="ip-footer">
      <div>End of Interview Kit</div>
      <div>Guidelines</div>
    </div>
  </div>

  <!-- CLOSING PAGE -->
  <div class="page closing-page">
    <div class="close-logo">
      <img src="{{logoBase64}}" class="close-logo-img" alt="Rifair AI">
    </div>
    <div class="close-tagline">Building a fairer future for talent, one audit at a time.</div>
    
    <div class="close-cta">
      <h3>Ready to scale your inclusive hiring?</h3>
      <p>Invite your team members to Rifair AI to collaborate on bias-free interview kits and candidate evaluations.</p>
    </div>

    <div class="close-meta">
      Report ID: {{meta.reportId}}<br>
      Generated on: {{meta.generatedDate}}<br>
      rifair.ai · support@rifair.ai
    </div>
  </div>

</body>
</html>
