# ============================================================
# Rifair AI — Frontend Environment Template
# ============================================================
# Copy to .env.local and fill in real values.
# NEVER add AI provider keys here — they belong in backend/.env
# ============================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY_HERE

NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app
BACKEND_URL=http://localhost:5001

NEXT_PUBLIC_APP_URL=https://your-app.com

# Next.js server-side only (never reaches browser):
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY_HERE
CRON_SECRET=your-cron-secret-min-16-chars

# ⛔ DO NOT ADD THESE HERE:
# GROQ_API_KEY_*    → belongs in backend/.env
# GEMINI_API_KEY_*  → belongs in backend/.env
# OPENAI_API_KEY    → belongs in backend/.env
# RAZORPAY_KEY_*    → belongs in backend/.env
