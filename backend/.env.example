# ============================================================
# Rifair AI — Backend Environment Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is blocked by .gitignore and pre-commit hooks.
# ============================================================

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Auth (Clerk) ─────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# ── Database (Supabase) ──────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY_HERE

# ── AI Provider Fallback Chain ───────────────────────────────
# Order: GROQ_PRIMARY → GROQ_SECONDARY → GROQ_TERTIARY → GEMINI_PRIMARY → GEMINI_SECONDARY
# GROQ_API_KEY_PRIMARY is required. Others are optional fallbacks.

GROQ_API_KEY_PRIMARY=gsk_YOUR_PRIMARY_GROQ_KEY
GROQ_API_KEY_SECONDARY=gsk_YOUR_SECONDARY_GROQ_KEY
GROQ_API_KEY_TERTIARY=gsk_YOUR_TERTIARY_GROQ_KEY

GEMINI_API_KEY_PRIMARY=AIzaSy_YOUR_PRIMARY_GEMINI_KEY
GEMINI_API_KEY_SECONDARY=AIzaSy_YOUR_SECONDARY_GEMINI_KEY

# ── Optional AI Providers ────────────────────────────────────
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Payments (Razorpay) ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Internal ─────────────────────────────────────────────────
CRON_SECRET=generate-a-random-32-char-string-here
