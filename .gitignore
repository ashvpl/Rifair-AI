# ============================================================
# Rifair AI — Enterprise .gitignore
# ============================================================
# Zero-tolerance for secrets, keys, or credentials in version control.
# Pre-commit hook also enforces this programmatically.
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
node_modules_backup/
.pnp
.pnp.js

# ── Secrets & Credentials — NEVER COMMIT ────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.crt
*.pfx
*.secret
*.secrets
credentials.json
service-account.json
*.keystore
*.jks
gcp-credentials.json
firebase-adminsdk*.json

# ── Database Dumps & Backups ─────────────────────────────────
*.sql
*.sqlite
*.sqlite3
*.db
dump.rdb
/backups/
/dumps/
*.backup
*.bak

# ── Debug & Logs ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
error_logs.txt
test_log.txt
dev_error.log
dev_error_log.txt

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
.next/cache/
.next/analyze/

# ── Build Output ─────────────────────────────────────────────
build/
dist/
.turbo/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.DS_Store

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── IDE ──────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Backend scratch/test files ───────────────────────────────
backend/test_*.js
backend/tester*.js
backend/list_models.js
backend/scratch/
backend/*.pid
backend/fix_sub.js
backend/scratch_*.js

# ── Frontend scratch/test files ──────────────────────────────
frontend/test_*.js
frontend/test_*.ts
frontend/test-*.js
frontend/test_adapter*.js

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── TypeScript build info ────────────────────────────────────
*.tsbuildinfo

# Hackathon datasets
candidates.jsonl
sample_candidates.json

# Generated ranking outputs
submission.csv
top_candidates.csv
top_candidates.xlsx
demo-results.json
demo-metrics.json

# Large exports
*.xlsx
*.xls

# Local datasets
datasets/
data/
